---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const keymapRaw = readFileSync(resolve(process.cwd(), '../config/keymap.json'), 'utf-8');
const { keymap } = JSON.parse(keymapRaw) as { keymap: Record<string, string> };

const kcToChar = (kc: string): string => {
	if (!kc) return '';
	if (kc === 'KC_SPC') return 'space';
	const m = kc.match(/^KC_([A-Z])$/);
	return m ? m[1] : kc;
};

// Estilos de cada tecla: superfície, texto, borda inferior (profundidade), posição y e separação
const KEY_STYLE: Record<string, {
	surface: string; labelColor: string; depth: string; ring: string;
	badgeBg: string; badgeText: string; badgeDepth: string;
	yOffset: string; mr: string;
	badgeOffset: string; badgeMr: string;
}> = {
	K1: { surface: 'from-violet-400 to-violet-600', labelColor: 'text-violet-100/80', depth: 'border-violet-800', ring: 'ring-white/20', badgeBg: 'bg-violet-500', badgeText: 'text-violet-100', badgeDepth: 'border-violet-700', yOffset: '',              mr: '',    badgeOffset: '',              badgeMr: ''      },
	K2: { surface: 'from-orange-300 to-orange-500', labelColor: 'text-orange-900/70', depth: 'border-orange-600', ring: 'ring-white/30', badgeBg: 'bg-orange-400', badgeText: 'text-orange-900', badgeDepth: 'border-orange-600', yOffset: '-translate-y-3', mr: '',    badgeOffset: '-translate-y-1', badgeMr: ''      },
	K3: { surface: 'from-rose-400 to-rose-600',     labelColor: 'text-rose-100/80',   depth: 'border-rose-800',   ring: 'ring-white/20', badgeBg: 'bg-rose-500',   badgeText: 'text-rose-100',   badgeDepth: 'border-rose-700',   yOffset: '',              mr: '',    badgeOffset: '',              badgeMr: ''      },
	K4: { surface: 'from-white to-slate-200',        labelColor: 'text-slate-500/80',  depth: 'border-slate-400',  ring: 'ring-white/60', badgeBg: 'bg-slate-200',  badgeText: 'text-slate-600',  badgeDepth: 'border-slate-400',  yOffset: 'translate-y-3',  mr: '',    badgeOffset: 'translate-y-1',  badgeMr: ''      },
	K5: { surface: 'from-sky-200 to-sky-300',        labelColor: 'text-sky-900/70',    depth: 'border-sky-500',    ring: 'ring-white/40', badgeBg: 'bg-sky-300',    badgeText: 'text-sky-900',    badgeDepth: 'border-sky-500',    yOffset: '',              mr: 'mr-8', badgeOffset: '',              badgeMr: 'mr-2'  },
};

// Ordem de exibição no teclado visual
const displayOrder = ['K5', 'K1', 'K2', 'K3', 'K4'] as const;

// Entradas da legenda, filtrando vazias e ordenando por letra resultado
const legendEntries = Object.entries(keymap)
	.filter(([, v]) => v !== '')
	.map(([combo, kc]) => ({ keys: combo.split('_'), char: kcToChar(kc) }))
	.sort((a, b) => {
		if (a.char === '·') return 1;
		if (b.char === '·') return -1;
		return a.char.localeCompare(b.char);
	});
---

<Layout>
	<div
		class="relative min-h-screen overflow-hidden bg-slate-950 text-slate-100"
		aria-label="Keycass Trompete"
	>
		<div
			class="pointer-events-none absolute -left-32 top-0 h-96 w-96 rounded-full bg-cyan-500/20 blur-[100px]"
			aria-hidden="true"
		>
		</div>
		<div
			class="pointer-events-none absolute -right-24 bottom-0 h-80 w-80 rounded-full bg-violet-600/25 blur-[90px]"
			aria-hidden="true"
		>
		</div>
		<div
			class="pointer-events-none absolute left-1/2 top-1/3 h-64 w-64 -translate-x-1/2 rounded-full bg-indigo-500/10 blur-[80px]"
			aria-hidden="true"
		>
		</div>

		<div
			x-data
			class="relative mx-auto flex min-h-screen max-w-lg flex-col px-6 pb-16 pt-14 sm:px-8 sm:pt-20"
		>
			<header class="mb-12 text-center sm:mb-14">
				<p
					class="mb-3 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium tracking-wide text-cyan-300/90"
				>
					<span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.8)]"
					></span>
					Web Speech API
				</p>
				<h1
					class="bg-linear-to-br from-white via-slate-100 to-slate-400 bg-clip-text text-4xl font-bold tracking-tight text-transparent sm:text-5xl"
				>
					Keycass Trompete
				</h1>
				<p class="mt-4 max-w-md text-pretty text-sm leading-relaxed text-slate-400 sm:text-base">
					Escolhe uma voz em português (Brasil) para usar com síntese de fala no navegador.
				</p>
			</header>

			<section
				class="rounded-2xl border border-white/10 bg-slate-900/60 p-6 shadow-2xl shadow-black/40 backdrop-blur-xl sm:p-8"
			>
				<label
					for="voice"
					class="mb-3 block text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"
				>
					voice
				</label>
				<div class="relative">
					<select
						id="voice"
						name="voice"
						disabled
						@change="$store.speech.voiceURI = $event.target.value"
						class="w-full appearance-none rounded-xl border border-slate-600/80 bg-slate-950/80 py-3.5 pl-4 pr-10 text-sm font-medium text-slate-100 shadow-inner outline-none transition focus:border-cyan-500/60 focus:ring-2 focus:ring-cyan-500/30 disabled:cursor-wait disabled:opacity-70"
					>
						<option value="">A carregar vozes…</option>
					</select>
					<span
						class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-slate-500"
						aria-hidden="true"
					>
						<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
						</svg>
					</span>
				</div>
				<p class="mt-4 text-xs leading-relaxed text-slate-500">
					A lista depende do sistema e do browser (Chrome, Edge e Safari costumam expor várias vozes
					<code class="rounded bg-slate-800 px-1 py-0.5 text-slate-300">pt-BR</code>).
				</p>
			</section>

			<section
				class="mt-4 rounded-2xl border border-white/10 bg-slate-900/60 p-6 shadow-2xl shadow-black/40 backdrop-blur-xl sm:p-8"
			>
				<div class="flex flex-col items-center gap-4">
					<div
						class="flex h-28 w-28 items-center justify-center rounded-2xl border border-white/10 bg-slate-950/80"
					>
						<span
							x-text="$store.speech.lastKey === ' ' ? '·' : ($store.speech.lastKey || '…')"
							class="font-mono text-6xl font-bold text-cyan-300 select-none"
						></span>
					</div>
					<p
						x-text="$store.speech.currentText || 'aguardando entrada…'"
						class="min-h-6 w-full break-all text-center font-mono text-sm text-slate-400"
					></p>
				</div>
			</section>
			<section
				class="mt-4 rounded-2xl border border-white/10 bg-slate-900/60 p-6 shadow-2xl shadow-black/40 backdrop-blur-xl sm:p-8"
			>
				<div class="flex items-center gap-2 py-6">
					{displayOrder.map((key) => {
						const s = KEY_STYLE[key];
						const num = key.replace('K', '');
						return (
							<div class={`relative h-14 w-14 shrink-0 cursor-default select-none rounded-t-xl rounded-b-lg border-b-[5px] bg-linear-to-b shadow-lg shadow-black/40 ring-1 ring-inset ${s.surface} ${s.depth} ${s.ring} ${s.yOffset} ${s.mr}`}>
								<span class={`absolute left-2 top-1.5 text-xs font-bold ${s.labelColor}`}>{num}</span>
							</div>
						);
					})}
				</div>
			</section>

			<section
				class="mt-4 rounded-2xl border border-white/10 bg-slate-900/60 p-6 shadow-2xl shadow-black/40 backdrop-blur-xl sm:p-8"
			>
				<p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">legenda</p>
				<div class="grid grid-cols-3 gap-2">
					{legendEntries.map(({ keys, char }) => (
						<div class="flex flex-col items-center gap-3 rounded-xl border border-white/5 bg-slate-950/50 px-2 py-4">
							<div class="flex items-center py-1">
								{displayOrder.map((key) => {
									const s = KEY_STYLE[key];
									const num = key.replace('K', '');
									const active = keys.includes(key);
									return (
										<span class={`inline-flex h-5 w-5 items-center justify-center rounded border-b-2 text-[9px] font-bold transition-opacity ${s.badgeBg} ${s.badgeText} ${s.badgeDepth} ${s.badgeOffset} ${s.badgeMr} ${active ? 'opacity-100' : 'opacity-20'}`}>
											{num}
										</span>
									);
								})}
							</div>
							<span class="font-mono text-xl font-bold text-slate-100">{char}</span>
							<span class="text-[10px] text-slate-500">{keys.map(k => k.replace('K', '')).join(' + ')}</span>
						</div>
					))}
				</div>
			</section>
		</div>
	</div>
</Layout>

<script>
	import Alpine from 'alpinejs';
	import { initPtBrVoiceSelect } from '../scripts/ptBrVoices';
	import { updateKeydown } from '../scripts/keydown';

	Alpine.store('speech', { voiceURI: '', lastKey: '', currentText: '' });

	const syncVoiceToStore = () => {
		const select = document.getElementById('voice') as HTMLSelectElement;
		if (select?.value) {
			(Alpine.store('speech') as { voiceURI: string }).voiceURI = select.value;
		}
	};

	document.addEventListener('keydown', updateKeydown);
	initPtBrVoiceSelect('voice');
	speechSynthesis.addEventListener('voiceschanged', syncVoiceToStore);
	syncVoiceToStore();
</script>
